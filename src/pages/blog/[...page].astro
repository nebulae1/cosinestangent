---
import MainLayout from "../../layouts/MainLayout.astro";
import PostCard from "../../components/PostCard.astro";
import CategoryCloud from "../../components/CategoryCloud.astro";
import Pagination from "../../components/Pagination.astro";
import type { Page } from "astro";

import { formatBlogPosts } from "../../js/utils";

interface BlogPost {
  frontmatter: Record<string, any>;
  url: string;
}

interface Props {
  page: Page<BlogPost>
}

export async function getStaticPaths({ paginate }) {
  const modules = import.meta.glob<any>("./*.md", { eager: true });
  const allPosts = Object.entries(modules).map(([path, mod]) => {
    // Astro markdown modules export with a 'frontmatter' property
    const frontmatter = mod.frontmatter || Object.entries(mod).reduce((acc, [key, value]) => {
      if (key !== 'default') {
        acc[key] = value;
      }
      return acc;
    }, {} as Record<string, any>);
    
    return {
      frontmatter,
      url: '/blog/' + path.replace(/^\.\//, '').replace(/\.md$/, '') + '/'
    };
  });
  
  const formattedPosts = formatBlogPosts(allPosts);

  return paginate(formattedPosts, {
    pageSize: 10,
  });
}

const { page } = Astro.props as Props;
---

<MainLayout title="Blog">
  <section class="container" aria-label="New Blog Posts">
    <h1 class="h1">New Blog Posts</h1>
    <div class="post-container">
      {
        page.data.map((post) => (
          <PostCard
            frontmatter={post.frontmatter}
            url={post.url}
            tagType="h2"
          />
        ))
      }
    </div>
    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
  </section>
  <aside class="container" aria-label="Blog categories">
    <h2 class="h3">Blog Categories</h2>
    <CategoryCloud showCount={true}/>
  </aside>
</MainLayout>
